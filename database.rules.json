{
  "rules": {
    "djursland_highscores": {
      ".read": true,
      ".write": false,
      "$entry": {
        ".write": "!data.exists()",
        "name": {
          ".validate": "newData.isString() && newData.val().length <= 30"
        },
        "city": {
          ".validate": "newData.isString() && newData.val().length <= 30"
        },
        "score": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 50000"
        },
        "ts": {
          ".validate": "newData.isNumber()"
        }
      }
    },
    "djursland_poll": {
      ".read": true,
      "votes": {
        ".write": true
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}